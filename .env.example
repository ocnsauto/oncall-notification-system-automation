# Flask
SECRET_KEY=your-random-secret-key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password
APP_TIMEZONE=Asia/Manila

# Gmail IMAP — Enable 2FA on Gmail, then generate an App Password under Security > App Passwords
GMAIL_ADDRESS=your-oncall@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Twilio — from console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_SMS_SENDER_ID=YourCompanyID

# ClickSend (Optional alternative for SMS if Twilio fails)
CLICKSEND_USERNAME=
CLICKSEND_API_KEY=
CLICKSEND_SENDER_ID=

# Notification templates (edit these freely)
COMPANY_NAME=YourCompanyName
TTS_TEMPLATE=This is an automated oncall notification from {company_name}. A network incident has been reported. Incident reference: {email_subject}. Details: {email_body_snippet}. This call was placed automatically. Please respond immediately. A follow-up text message with full details will follow this call.
SMS_TEMPLATE=[ONCALL ALERT] {company_name} | Incident: {email_subject} | {email_body_snippet} | Respond immediately.

# Demo settings
AUTO_APPROVE_SCHEDULE=false
INCIDENT_COOLDOWN_MINUTES=5
POLL_INTERVAL_SECONDS=30
